# =============================================================================
# REST Client environment variables — EXAMPLE
#
# DO NOT edit this file directly. Copy it to .env, then fill in real values:
#
#   cp http/.env.example http/.env
#
# .env is gitignored; .env.example is committed.
# Referenced from .http files via {{$dotenv VAR_NAME}}.
# REST Client reads the .env located in the SAME directory as the .http file.
# =============================================================================

BASE_URL=http://localhost:8000

# Auth — replace with real credentials (never commit .env)
API_KEY=your-api-key-here
BEARER_TOKEN=your-bearer-token-here
