# =============================================================================
# REST Client sample — reference for authoring new .http files
#
# Prerequisites:
#   - VS Code extension: "REST Client" (humao.rest-client)
#   - Create http/.env (copy from http/.env.example) with your real values
#
# Usage:
#   Click "Send Request" above any ### block, or press Ctrl+Alt+R
# =============================================================================

# Shared values come from http/.env via the {{$dotenv VAR}} system variable.
# REST Client reads the .env located in the SAME directory as this .http file,
# so every .http file under http/ shares the same values — no copy step needed.
# (NOTE: plain @file variables are file-scoped and are NOT shared across files;
#  use {{$dotenv VAR}} for anything that must be shared.)

# ---------------------------------------------------------------------------
# File-local variables (constant within this file)
# ---------------------------------------------------------------------------
@content_type = application/json
@resource_id  = 42
@page         = 1
@per_page     = 20


###############################################################################
# 1. Simple GET — no auth
###############################################################################

### GET public JSON placeholder
GET https://jsonplaceholder.typicode.com/posts/{{resource_id}}
Accept: {{content_type}}


###############################################################################
# 2. GET with query parameters
###############################################################################

### List posts with pagination
GET https://jsonplaceholder.typicode.com/posts?_page={{page}}&_limit={{per_page}}
Accept: {{content_type}}


###############################################################################
# 3. POST with JSON body
###############################################################################

### Create a new post
POST https://jsonplaceholder.typicode.com/posts
Content-Type: {{content_type}}

{
  "title": "Hello from REST Client",
  "body": "This is a sample request body.",
  "userId": 1
}


###############################################################################
# 4. PUT — full update
###############################################################################

### Replace post
PUT https://jsonplaceholder.typicode.com/posts/{{resource_id}}
Content-Type: {{content_type}}

{
  "id": {{resource_id}},
  "title": "Updated title",
  "body": "Updated body.",
  "userId": 1
}


###############################################################################
# 5. PATCH — partial update
###############################################################################

### Patch post title only
PATCH https://jsonplaceholder.typicode.com/posts/{{resource_id}}
Content-Type: {{content_type}}

{
  "title": "Patched title"
}


###############################################################################
# 6. DELETE
###############################################################################

### Delete a post
DELETE https://jsonplaceholder.typicode.com/posts/{{resource_id}}


###############################################################################
# 7. Bearer token auth (uses BEARER_TOKEN from http/.env)
###############################################################################

### Authenticated GET (placeholder — replace URL with a real auth-protected endpoint)
GET {{$dotenv BASE_URL}}/api/me
Authorization: Bearer {{$dotenv BEARER_TOKEN}}
Accept: {{content_type}}


###############################################################################
# 8. API-key header auth
###############################################################################

### API key in header
GET {{$dotenv BASE_URL}}/api/items
X-Api-Key: {{$dotenv API_KEY}}
Accept: {{content_type}}


###############################################################################
# 9. Response variable chaining
#    Capture a value from one response and reuse it in the next request.
###############################################################################

### Step 1 — create a post and capture its id
# @name createPost
POST https://jsonplaceholder.typicode.com/posts
Content-Type: {{content_type}}

{
  "title": "Chained request demo",
  "body": "Step 1 creates this resource.",
  "userId": 1
}

### Step 2 — use the captured id from Step 1
# The syntax is {{<requestName>.response.body.<jsonPath>}}
GET https://jsonplaceholder.typicode.com/posts/{{createPost.response.body.id}}
Accept: {{content_type}}


###############################################################################
# 10. Multipart form-data
###############################################################################

### Upload a file (data files live in http/data/, referenced by relative path)
POST https://httpbin.org/post
Content-Type: multipart/form-data; boundary=----Boundary

------Boundary
Content-Disposition: form-data; name="description"

Sample upload
------Boundary
Content-Disposition: form-data; name="file"; filename="sample.csv"
Content-Type: text/csv

< ./data/sample.csv
------Boundary--


###############################################################################
# 11. Basic auth (base64-encoded credentials)
###############################################################################

### Basic auth via Authorization header
GET https://httpbin.org/basic-auth/user/pass
Authorization: Basic dXNlcjpwYXNz


###############################################################################
# 12. Custom request with multiple headers
###############################################################################

### Rich headers example
GET https://httpbin.org/headers
Accept: application/json
X-Correlation-Id: req-{{$guid}}
X-Timestamp: {{$datetime iso8601}}
User-Agent: VSCode-RestClient/1.0
Cache-Control: no-cache


###############################################################################
# 13. Send a data file as the raw request body (CSV, etc.)
#     Data files live in http/data/ and are referenced by a path RELATIVE to
#     this .http file. REST Client streams the file contents as the body.
#       < ./path   — send the file as-is (no variable substitution)
#       <@ ./path  — substitute {{variables}} inside the file before sending
#                    (e.g. <@ ./data/template.csv); add an encoding like
#                    <@latin1 ./data/legacy.csv if the file is not UTF-8.
###############################################################################

### Upload a CSV file as the body
POST https://httpbin.org/post
Content-Type: text/csv

< ./data/sample.csv


###############################################################################
# 14. Send a data file inside multipart/form-data
###############################################################################

### Upload sample.csv as a named file part
POST https://httpbin.org/post
Content-Type: multipart/form-data; boundary=----Boundary

------Boundary
Content-Disposition: form-data; name="dataset"; filename="sample.csv"
Content-Type: text/csv

< ./data/sample.csv
------Boundary--


###############################################################################
# Built-in dynamic variables (no setup needed)
#   {{$guid}}              — random UUID v4
#   {{$timestamp}}         — current Unix timestamp (seconds)
#   {{$datetime iso8601}}  — current datetime in ISO 8601
#   {{$datetime rfc1123}}  — current datetime in RFC 1123
#   {{$randomInt min max}} — random integer in [min, max]
###############################################################################

### Echo dynamic variables
GET https://httpbin.org/get?guid={{$guid}}&ts={{$timestamp}}&rand={{$randomInt 1 100}}
Accept: {{content_type}}
