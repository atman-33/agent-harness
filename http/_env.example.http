# =============================================================================
# REST Client environment variables — EXAMPLE
#
# DO NOT edit this file directly.
# Copy it to _env.http, then fill in your real values:
#
#   cp http/_env.example.http http/_env.http
#
# _env.http is gitignored; _env.example.http is committed.
# =============================================================================

# Active environment: local | staging | prod
@env = local

@base_url_local   = http://localhost:8000
@base_url_staging = https://staging.example.com
@base_url_prod    = https://api.example.com

# Change @env above to switch between the URLs below
@base_url = {{base_url_local}}

# Auth — replace with real credentials (never commit _env.http)
@api_key      = your-api-key-here
@bearer_token = your-bearer-token-here

# Common content type
@content_type = application/json
